# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env with real secrets to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=tryoutapp
POSTGRES_USER=tryout
POSTGRES_PASSWORD=change_me_to_a_strong_password

# DB connection (backend reads these; must match Postgres values above)
DB_HOST=tryout_db
DB_PORT=5432
DB_NAME=tryoutapp
DB_USER=tryout
DB_PASS=change_me_to_a_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# JWT_SECRET: minimum 32 random characters. Use `openssl rand -hex 32` to generate.
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

NODE_ENV=development

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated allowed origins. Required when NODE_ENV=production.
# CORS_ORIGINS=https://your-domain.com

# ── Pool sizing (optional) ────────────────────────────────────────────────────
# DB_POOL_MAX=10
# DB_POOL_IDLE_MS=30000

# ── Mail (local dev uses Mailhog — no changes needed) ────────────────────────
MAIL_HOST=mailhog
MAIL_PORT=1025

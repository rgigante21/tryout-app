{
  "name": "tryout-app-backend",
  "version": "1.0.0",
  "description": "Hockey Tryout App - API Server",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "audit-tenancy": "node ../scripts/audit-tenancy.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^bcrypt$": "bcryptjs"
    }
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bcryptjs": "^3.0.3",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
